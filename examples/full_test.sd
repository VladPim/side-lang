## =====================================================
## Full Test Suite for Side Language - All Features
## =====================================================

## --- Struct definitions (top level) ---
struct Point {
    double x
    double y
}

struct Rectangle {
    Point top_left
    Point bottom_right
}

## --- Struct methods (top level) ---
fn Point.distance() -> double {
    return sqrt(self.x * self.x + self.y * self.y)
}

fn Point.scale(double factor) -> Point {
    let Point p = Point { self.x * factor, self.y * factor }
    return p
}

fn Rectangle.width() -> double {
    return self.bottom_right.x - self.top_left.x
}

fn Rectangle.height() -> double {
    return self.bottom_right.y - self.top_left.y
}

## --- Main function ---
fn main() {
    io.print("=== 1. Arithmetic ===")
    let int a = 10
    let int b = 3
    let int sum = a + b
    let int diff = a - b
    let int prod = a * b
    let int quot = a / b
    let int mod = a - (a / b) * b
    io.print("sum=", sum, " diff=", diff, " prod=", prod, " quot=", quot, " mod=", mod)

    let int expr1 = 2 + 3 * 4
    let int expr2 = (2 + 3) * 4
    io.print("2+3*4=", expr1, " (2+3)*4=", expr2)

    io.print("=== 2. Logical Operators ===")
    let int x = 5
    let int y = 10
    if x > 0 and x < 10 {
        io.print("x in (0,10): OK")
    } else {
        io.print("x in (0,10): FAILED")
    }
    if not (x == y) {
        io.print("not (x == y): OK")
    }
    if x < y or x > 20 {
        io.print("x < y or x > 20: OK")
    }

    io.print("=== 3. Conditional Statements ===")
    let int score = 85
    if score >= 90 {
        io.print("Grade: A")
    } else if score >= 80 {
        io.print("Grade: B (OK)")
    } else if score >= 70 {
        io.print("Grade: C")
    } else {
        io.print("Grade: F")
    }

    io.print("=== 4. Ternary Operator ===")
    let int age = 20
    let str status = (age >= 18) ? "Adult" : "Minor"
    io.print("Age ", age, " -> ", status)
    let double price = (age < 18) ? 5.0 : 10.0
    io.print("Price = ", price)

    io.print("=== 5. While Loop ===")
    let int counter = 0
    let int while_sum = 0
    while counter < 5 {
        while_sum = while_sum + counter
        counter = counter + 1
    }
    io.print("Sum 0..4 = ", while_sum, " (expected 10)")

    io.print("=== 6. For Loop ===")
    let int for_sum = 0
    for i = 0, i < 5, i = i + 1 {
        for_sum = for_sum + i
    }
    io.print("Sum 0..4 = ", for_sum, " (expected 10)")

    io.print("=== 7. Int Arrays ===")
    let int[] iarr = []
    push(iarr, 100)
    push(iarr, 200)
    push(iarr, 300)
    let int iarr_len = len(iarr)
    io.print("Length = ", iarr_len, " (expected 3)")
    io.print("Elements: ", iarr[0], " ", iarr[1], " ", iarr[2], " (expected 100 200 300)")
    pop(iarr)
    io.print("After pop length = ", len(iarr), " (expected 2)")

    io.print("=== 8. Double Arrays ===")
    let double[] darr = []
    push(darr, 1.5)
    push(darr, 2.5)
    push(darr, 3.5)
    let int darr_len = len(darr)
    io.print("Length = ", darr_len, " (expected 3)")
    io.print("Elements: ", darr[0], " ", darr[1], " ", darr[2], " (expected 1.5 2.5 3.5)")
    pop(darr)
    io.print("After pop length = ", len(darr), " (expected 2)")

    io.print("=== 9. Strings ===")
    let str greeting = "Hello"
    let str target = "Side"
    let str combined = greeting + " " + target + "!"
    io.print("Concatenated: ", combined, " (expected Hello Side!)")
    if combined == "Hello Side!" {
        io.print("String equality: OK")
    } else {
        io.print("String equality: FAILED")
    }
    if combined != "Hello World" {
        io.print("String inequality: OK")
    }

    io.print("=== 10. Built-in Functions ===")
    let int tm = time()
    io.print("time() = ", tm, " ms (positive)")

    let double sq = sqrt(16.0)
    io.print("sqrt(16) = ", sq, " (expected 4)")

    let double av = fabs(-3.14)
    io.print("fabs(-3.14) = ", av, " (expected 3.14)")

    let double pw = pow(2.0, 3.0)
    io.print("pow(2,3) = ", pw, " (expected 8)")

    let int rnd = rand()
    io.print("rand() = ", rnd, " (random)")

    let str num_str = str(123)
    io.print("str(123) = ", num_str, " (expected '123')")

    let int parsed = int("456")
    io.print("int('456') = ", parsed, " (expected 456)")

    io.print("=== 11. Structs and Methods ===")
    let Point p1 = Point { 3.0, 4.0 }
    let double dist = p1.distance()
    io.print("p1.distance() = ", dist, " (expected 5)")

    let Point p2 = p1.scale(2.0)
    io.print("p2 = (", p2.x, ", ", p2.y, ") (expected (6, 8))")

    let double dist2 = p2.distance()
    io.print("p2.distance() = ", dist2, " (expected 10)")

    io.print("=== 12. Compound Assignment ===")
    let int z = 5
    z += 3
    io.print("z += 3 -> ", z, " (expected 8)")
    z -= 2
    io.print("z -= 2 -> ", z, " (expected 6)")
    z *= 2
    io.print("z *= 2 -> ", z, " (expected 12)")
    z /= 3
    io.print("z /= 3 -> ", z, " (expected 4)")

    io.print("=== 13. Nested Structs ===")
    let Rectangle rect = Rectangle { Point { 0.0, 0.0 }, Point { 5.0, 3.0 } }
    let double w = rect.width()
    let double h = rect.height()
    io.print("Rect width = ", w, " height = ", h, " (expected 5, 3)")

    io.print("")
    io.print("=== All tests passed successfully! ===")
}