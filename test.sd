## Определяем структуру Point
struct Point {
    double x
    double y
}

## Функция, возвращающая структуру
fn make_point(double x, double y) -> Point {
    let Point p = Point { x, y }
    return p
}

## Функция, принимающая структуру и вычисляющая расстояние до начала координат
fn distance(Point p) -> double {
    return sqrt(p.x * p.x + p.y * p.y)
}

## Основная функция
fn main() {
    io.print("=== Тестирование языка Side ===")
    
    ## Арифметика
    let int a = 10
    let int b = 3
    let int sum = a + b
    let int diff = a - b
    let int prod = a * b
    let int quot = a / b
    io.print("1. Арифметика: sum=", sum, " diff=", diff, " prod=", prod, " quot=", quot)
    
    ## Логические операции
    let int x = 5
    if x > 0 and x < 10 {
        io.print("2. Логика: x in (0,10) - OK")
    } else {
        io.print("2. Логика: FAILED")
    }
    
    if not (x == 0) {
        io.print("2b. not (x==0) - OK")
    }
    
    ## Условный оператор if-else-if
    let int score = 85
    if score >= 90 {
        io.print("3. Grade: A")
    } else if score >= 80 {
        io.print("3. Grade: B (OK)")
    } else {
        io.print("3. Grade: FAILED")
    }
    
    ## Цикл while
    let int counter = 0
    let int while_sum = 0
    while counter < 5 {
        while_sum = while_sum + counter
        counter = counter + 1
    }
    io.print("4. While sum 0..4 = ", while_sum, " (expected 10)")
    
    ## Цикл for
    let int for_sum = 0
    for i = 0, i < 5, i = i + 1 {
        for_sum = for_sum + i
    }
    io.print("5. For sum 0..4 = ", for_sum, " (expected 10)")
    
    ## Массивы int
    let int[] iarr = []
    push(iarr, 100)
    push(iarr, 200)
    push(iarr, 300)
    let int iarr_len = len(iarr)
    io.print("6. Int array length = ", iarr_len, " (expected 3)")
    io.print("6b. Elements: ", iarr[0], " ", iarr[1], " ", iarr[2], " (expected 100 200 300)")
    pop(iarr)
    io.print("6c. After pop length = ", len(iarr), " (expected 2)")
    
    ## Массивы double
    let double[] darr = []
    push(darr, 1.5)
    push(darr, 2.5)
    push(darr, 3.5)
    let int darr_len = len(darr)
    io.print("7. Double array length = ", darr_len, " (expected 3)")
    io.print("7b. Elements: ", darr[0], " ", darr[1], " ", darr[2], " (expected 1.5 2.5 3.5)")
    pop(darr)
    io.print("7c. After pop length = ", len(darr), " (expected 2)")
    
    ## Строки
    let str greeting = "Hello"
    let str target = "Side"
    io.print("8. Strings: ", greeting, ", ", target, "! (expected Hello, Side!)")
    
    ## Встроенные функции
    let double da = 3.0
    let double db = 4.0
    let double dsum = add_double(da, db)
    io.print("9. add_double(3,4) = ", dsum, " (expected 7)")
    
    let int f5 = factorial(5)
    io.print("9b. factorial(5) = ", f5, " (expected 120)")
    
    let int tm = time()
    io.print("10a. time() = ", tm, " ms (any positive number)")
    
    let double sq = sqrt(16.0)
    io.print("10b. sqrt(16) = ", sq, " (expected 4)")
    
    let double av = fabs(-3.14)
    io.print("10c. fabs(-3.14) = ", av, " (expected 3.14)")
    
    let double pw = pow(2.0, 3.0)
    io.print("10d. pow(2,3) = ", pw, " (expected 8)")
    
    let int rnd = rand()
    io.print("10e. rand() = ", rnd, " (random integer)")
    
    let str num_str = str(123)
    io.print("10f. str(123) = ", num_str, " (expected '123')")
    
    let int parsed = int("456")
    io.print("10g. int('456') = ", parsed, " (expected 456)")
    
    ## Структуры
    let Point p1 = make_point(3.0, 4.0)
    io.print("11a. p1.x = ", p1.x, " p1.y = ", p1.y, " (expected 3.0, 4.0)")
    let double dist = distance(p1)
    io.print("11b. distance to origin = ", dist, " (expected 5.0)")
    
    io.print("")
    io.print("=== Все тесты пройдены! ===")
}

## Вспомогательная функция add_double
fn add_double(double a, double b) -> double {
    return a + b
}

## Вспомогательная функция factorial
fn factorial(int n) -> int {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}